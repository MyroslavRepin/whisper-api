# Database (external PostgreSQL service)
DATABASE_URL=postgresql://user:password@host:5432/whisper_api

# Redis (external service for ARQ)
REDIS_URL=redis://host:6379

# MinIO/S3 (external object storage service)
S3_ENDPOINT=https://your-minio-endpoint.com
S3_USERNAME=your_s3_username
S3_PASSWORD=your_s3_password
S3_BUCKET=whisper-audio

# Whisper Model (tiny, base, small, medium, large)
WHISPER_MODEL=tiny
MAX_FILE_DURATION=10800
TRANSCRIPTION_CHUNK_SECONDS=600

# Temp files
TMP_FILE_LOCATION=/tmp/

# Email Services
RESEND_API_KEY=your_resend_api_key_here
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=your_mailgun_domain_here
